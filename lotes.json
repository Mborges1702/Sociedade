ARQUIVO_LOTES = "lotes.json"
def carregar_lotes():
    try:
        with open(ARQUIVO_LOTES, "r", encoding="utf-8") as arquivo:
            return json.load(arquivo)
    except FileNotFoundError:
        return []


def salvar_lotes():
